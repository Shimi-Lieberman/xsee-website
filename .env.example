# Copy to .env.local for local development (do not commit secrets).

# Vercel Postgres / Neon (set automatically on Vercel)
POSTGRES_URL=
POSTGRES_PRISMA_URL=
POSTGRES_URL_NON_POOLING=
POSTGRES_USER=
POSTGRES_HOST=
POSTGRES_PASSWORD=
POSTGRES_DATABASE=

# Resend (transactional email)
RESEND_API_KEY=your-resend-api-key-here
RESEND_FROM_EMAIL=notifications@xsee.io
ADMIN_EMAIL=admin@xsee.io

# Optional: free-scan forward to platform API
# XSEE_PLATFORM_API_URL=https://app.xsee.io

# Paddle (pricing checkout — Professional tier)
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=
NEXT_PUBLIC_PADDLE_STARTER_PRICE_ID=
NEXT_PUBLIC_PADDLE_PRO_PRICE_ID=
NEXT_PUBLIC_PADDLE_ENVIRONMENT=production
